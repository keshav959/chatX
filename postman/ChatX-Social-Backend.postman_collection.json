{
  "info": {
    "name": "ChatX Social Backend",
    "_postman_id": "9e0192fe-9d38-4d7d-8be7-7d1904ce7e2a",
    "description": "MVP API collection for ChatX Spring Boot backend.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "['accessTokenA','accessTokenB','refreshTokenA','refreshTokenB'].forEach((k) => {",
          "  const cv = pm.collectionVariables.get(k);",
          "  const ev = pm.environment.get(k);",
          "  if (typeof cv === 'string') {",
          "    pm.collectionVariables.set(k, cv.replace(/^\\\"|\\\"$/g, '').trim());",
          "  }",
          "  if (typeof ev === 'string') {",
          "    pm.environment.set(k, ev.replace(/^\\\"|\\\"$/g, '').trim());",
          "  }",
          "});"
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (pm.response.code !== 403) {",
          "  return;",
          "}",
          "",
          "const requestUrl = pm.request.url.toString();",
          "if (requestUrl.includes('/api/auth/')) {",
          "  return;",
          "}",
          "",
          "const authHeader = pm.request.headers.get('Authorization') || '';",
          "const useB = authHeader.includes('accessTokenB');",
          "const suffix = useB ? 'B' : 'A';",
          "const refreshKey = `refreshToken${suffix}`;",
          "const accessKey = `accessToken${suffix}`;",
          "const refreshToken = pm.environment.get(refreshKey) || pm.collectionVariables.get(refreshKey);",
          "",
          "if (!refreshToken) {",
          "  console.log('403 received and no refresh token available. Login again.');",
          "  return;",
          "}",
          "",
          "pm.sendRequest({",
          "  url: `${pm.collectionVariables.get('baseUrl') || pm.environment.get('baseUrl')}/api/auth/refresh`,",
          "  method: 'POST',",
          "  header: { 'Content-Type': 'application/json' },",
          "  body: {",
          "    mode: 'raw',",
          "    raw: JSON.stringify({ refreshToken })",
          "  }",
          "}, function (err, res) {",
          "  if (err || !res || res.code !== 200) {",
          "    console.log('Token refresh failed. Please run Login again.');",
          "    return;",
          "  }",
          "  const json = res.json();",
          "  if (json.accessToken) {",
          "    pm.collectionVariables.set(accessKey, json.accessToken);",
          "    pm.environment.set(accessKey, json.accessToken);",
          "  }",
          "  if (json.refreshToken) {",
          "    pm.collectionVariables.set(refreshKey, json.refreshToken);",
          "    pm.environment.set(refreshKey, json.refreshToken);",
          "  }",
          "  console.log('Token refreshed. Re-send the previous request once.');",
          "});"
        ]
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8090" },
    { "key": "accessTokenA", "value": "" },
    { "key": "accessTokenB", "value": "" },
    { "key": "refreshTokenA", "value": "" },
    { "key": "refreshTokenB", "value": "" },
    { "key": "userIdA", "value": "" },
    { "key": "userIdB", "value": "" },
    { "key": "chatId", "value": "room1" }
